{
  "name": "wave-studio",
  "version": "0.1.1",
  "private": true,
  "description": "Open-source studio for authoring 3D gradient waves",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @wave3d/core build:standalone",
    "dev": "vite",
    "prebuild": "pnpm --filter @wave3d/core build:standalone",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wave3d/core": "workspace:*",
    "gifenc": "^1.0.3",
    "shiki": "^4.3.1",
    "tweakpane": "^4.0.5"
  },
  "devDependencies": {
    "@tweakpane/core": "^2.0.5",
    "@types/three": "^0.185.0",
    "vite": "^8.1.0"
  }
}

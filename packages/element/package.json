{
  "name": "@wave3d/element",
  "version": "0.3.0",
  "description": "Drop-in animated 3D gradient wave for Vue, Svelte, or plain HTML: the <wave-3d> custom element",
  "keywords": [
    "background",
    "custom-elements",
    "gradient",
    "svelte",
    "three",
    "vue",
    "wave",
    "web-components",
    "webgl"
  ],
  "homepage": "https://github.com/Amir-Abushanab/wave3d/tree/main/packages/element#readme",
  "bugs": "https://github.com/Amir-Abushanab/wave3d/issues",
  "license": "MIT",
  "author": "Amir Abushanab (https://github.com/Amir-Abushanab)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amir-Abushanab/wave3d.git",
    "directory": "packages/element"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "./src/index.ts",
    "./dist/index.js"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsdown"
  },
  "dependencies": {
    "@wave3d/core": "workspace:^"
  },
  "peerDependencies": {
    "@types/three": ">=0.180",
    "three": ">=0.180 <1"
  },
  "peerDependenciesMeta": {
    "@types/three": {
      "optional": true
    }
  }
}

{
  "name": "@wave3d/react",
  "version": "0.4.1",
  "description": "Drop-in animated 3D gradient wave for React: the <Wave3D> component",
  "keywords": [
    "animation",
    "background",
    "component",
    "gradient",
    "react",
    "three",
    "threejs",
    "wave",
    "webgl"
  ],
  "homepage": "https://github.com/Amir-Abushanab/wave3d/tree/main/packages/react#readme",
  "bugs": "https://github.com/Amir-Abushanab/wave3d/issues",
  "license": "MIT",
  "author": "Amir Abushanab (https://github.com/Amir-Abushanab)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amir-Abushanab/wave3d.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.tsx"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsdown"
  },
  "dependencies": {
    "@wave3d/core": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0"
  },
  "peerDependencies": {
    "@types/three": ">=0.180",
    "react": ">=18",
    "three": ">=0.180 <1"
  },
  "peerDependenciesMeta": {
    "@types/three": {
      "optional": true
    }
  }
}

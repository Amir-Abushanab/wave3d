{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "packages/core": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@tanstack/intent"]
    },
    "apps/studio": {
      "entry": ["src/preview.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@tweakpane/core"]
    },
    "apps/gallery": {
      "project": ["src/**/*.ts"]
    },
    "packages/react": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/element": {
      "project": ["src/**/*.ts"]
    }
  },
  "include": [
    "files",
    "dependencies",
    "devDependencies",
    "optionalPeerDependencies",
    "unlisted",
    "binaries",
    "unresolved",
    "catalog"
  ]
}

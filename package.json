{
  "name": "wave3d-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo for the @wave3d packages and the Wave Studio app",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "hooks:install": "git config core.hooksPath .githooks",
    "dev": "pnpm --filter wave-studio dev",
    "build": "pnpm -r build",
    "build:packages": "pnpm -r --filter \"@wave3d/*\" build",
    "pack:all": "pnpm -r --filter \"@wave3d/*\" exec pnpm pack",
    "preview": "pnpm --filter wave-studio preview",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "depcruise": "dependency-cruiser apps packages",
    "knip": "knip",
    "skill:validate": "intent validate packages/core/skills",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm depcruise && pnpm knip && pnpm skill:validate",
    "ncu": "pnpm dlx npm-check-updates"
  },
  "devDependencies": {
    "@tanstack/intent": "^0.3.4",
    "dependency-cruiser": "^18.0.0",
    "knip": "^6.23.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.9.0"
}

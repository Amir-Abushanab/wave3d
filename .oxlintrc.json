{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error"
  },
  "env": {
    "browser": true,
    "es2022": true
  },
  "rules": {
    "unicorn/no-array-sort": "off"
  },
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error"
  }
}
